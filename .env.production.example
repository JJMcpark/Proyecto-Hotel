# ═══════════════════════════════════════════════════════════════
#  .env de PRODUCCIÓN — Plantilla
# ═══════════════════════════════════════════════════════════════
# 1. Copiá este archivo a .env en la RAÍZ del proyecto (junto al docker-compose.yml)
#       cp .env.production.example .env
#
# 2. Rellenás los valores reales
#
# 3. Protegé el archivo:
#       chmod 600 .env
#
# ⚠️  NUNCA subas el .env al repositorio
# ═══════════════════════════════════════════════════════════════

# ── MySQL ──────────────────────────────────────────────────────
# Contraseña del usuario root de MySQL.
# Usá una contraseña FUERTE (mínimo 16 caracteres, letras, números, símbolos).
# Ejemplo para generar una:  openssl rand -base64 24
MYSQL_ROOT_PASSWORD=CAMBIAR_contraseña_fuerte_aqui

# ── Credenciales del backend para conectarse a MySQL ───────────
# Deben coincidir con MYSQL_ROOT_PASSWORD (usamos root por simplicidad)
DB_USERNAME=root
DB_PASSWORD=CAMBIAR_contraseña_fuerte_aqui
DB_FLYWAY_USERNAME=root
DB_FLYWAY_PASSWORD=CAMBIAR_contraseña_fuerte_aqui

# ── JWT (clave secreta para firmar tokens) ─────────────────────
# Generá una clave única con:  openssl rand -base64 32
# ⚠️  Si cambiás esta clave, TODOS los usuarios van a tener que
#     volver a loguearse (los tokens viejos quedan inválidos).
JWT_SECRET_KEY=CAMBIAR_genera_con_openssl_rand_base64_32

# ── CORS: URL pública del frontend ────────────────────────────
# ¿Tenés dominio con HTTPS?  → https://hotel.tudominio.com
# ¿Solo tenés IP?             → http://TU_IP_DEL_SERVIDOR
CORS_ALLOWED_ORIGIN=http://TU_IP_DEL_SERVIDOR

# ── Cookies seguras ───────────────────────────────────────────
# false = sin HTTPS (solo IP, o todavía no configuraste SSL)
# true  = con HTTPS (ya tenés certificado SSL con Certbot)
#
# ⚠️  Si ponés true sin tener HTTPS, el login NO va a funcionar
#     porque el navegador rechaza cookies "Secure" en HTTP.
COOKIE_SECURE=false
