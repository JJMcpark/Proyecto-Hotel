# Copia este archivo a .env y rellena los valores reales
# NUNCA subas .env al repositorio

# ── MySQL ──────────────────────────────────────────────────────
MYSQL_ROOT_PASSWORD=change_me_root

# ── Credenciales del backend ───────────────────────────────────
DB_USERNAME=root
DB_PASSWORD=change_me
DB_FLYWAY_USERNAME=root
DB_FLYWAY_PASSWORD=change_me

# ── JWT (clave Base64 de 256 bits) ────────────────────────────
# Genera una con: openssl rand -base64 32
JWT_SECRET_KEY=change_me_base64_256bit_key

# ── CORS: URL pública del frontend ────────────────────────────
# En local: http://localhost
# En producción: https://tudominio.com
CORS_ALLOWED_ORIGIN=http://localhost

# ── Cookies seguras (true en producción con HTTPS) ────────────
COOKIE_SECURE=false
