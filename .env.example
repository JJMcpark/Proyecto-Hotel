# Copy this file to .env and fill in real values before running docker-compose

# MySQL root password (used by docker-compose to init the MySQL container)
MYSQL_ROOT_PASSWORD=change_me

# Spring datasource credentials
DB_USERNAME=root
DB_PASSWORD=change_me
DB_FLYWAY_USERNAME=root
DB_FLYWAY_PASSWORD=change_me

# JWT secret — must be a Base64-encoded 256-bit key
JWT_SECRET_KEY=change_me_base64_256bit_key

# Frontend origin allowed by CORS (e.g. http://localhost:5173 or https://yourdomain.com)
CORS_ALLOWED_ORIGIN=http://localhost:5173
